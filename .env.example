# =============================================================================
# tts-elk configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.
#
#   cp .env.example .env
#   # edit .env
#   docker compose up -d
#
# All variables below are read by docker-compose.yml at start-up.
# =============================================================================

# ---- The Things Stack -------------------------------------------------------

# Hostname (no scheme, no trailing slash) of your TTS deployment.
# Examples:
#   <tenant>.eu1.cloud.thethings.industries  (TTS Cloud, EU1 — replace <tenant>)
#   <tenant>.nam1.cloud.thethings.industries (TTS Cloud, North America)
#   <tenant>.au1.cloud.thethings.industries  (TTS Cloud, Australia)
#   tts.example.com                          (self-hosted Enterprise / Open Source)
TTS_HOST=tts.example.com

# API key with read rights on the entities you want to observe.
# See README §3 for the minimum required rights.
TTS_API_KEY=NNSXS.replace-me

# Set to "true" only if your TTS deployment uses a self-signed cert and you
# accept the risk. Production / Cloud deployments should leave this "false".
TTS_INSECURE=false

# Comma-separated list of identifier kinds to subscribe to.
# Reduce this list to scope down (e.g. just "applications,gateways" for a
# device-traffic-only forwarder).
SUBSCRIBE_KINDS=applications,gateways,organizations,users,clients

# Regex (must include the surrounding /.../) restricting which event names
# are streamed. Default "/.+/" matches everything.
# Examples:
#   /^as\..+/      — only Application Server events
#   /^(ns|gs)\..+/ — Network Server + Gateway Server only
EVENT_NAMES_REGEX=/.+/

# How often (seconds) the forwarder re-lists entities and reopens streams,
# so newly-created applications/gateways start being captured.
REFRESH_INTERVAL=300

# Optional: subscribe to a hard-coded set of identifiers instead of
# discovering them via the list APIs. Useful when the API key has the
# *_INFO / *_TRAFFIC_READ rights but not the user-level *_LIST rights
# needed to enumerate entities. Format is a JSON object keyed by kind:
#
# STATIC_IDENTIFIERS={"gateways":[{"gateway_id":"my-gw"}],"applications":[{"application_id":"my-app"}]}
#
# Leave empty to use auto-discovery.
STATIC_IDENTIFIERS=

# ---- ELK stack --------------------------------------------------------------

# Pin to a single 8.x version across ES, Kibana and Logstash.
STACK_VERSION=8.13.4

# Passwords for the built-in 'elastic' superuser and the 'kibana_system'
# service account. Change these before exposing the stack to anything.
ELASTIC_PASSWORD=change-me-elastic
KIBANA_PASSWORD=change-me-kibana

# Encryption keys for Kibana saved objects (random strings ≥32 chars).
# Generate with:  openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=replace_with_openssl_rand_hex_32________________________________

# JVM heap — about half of the container's mem_limit.
ES_JAVA_OPTS=-Xms2g -Xmx2g
LS_JAVA_OPTS=-Xms512m -Xmx512m

# Container memory limits (also constrains the heap above).
ES_MEM_LIMIT=4g
KB_MEM_LIMIT=1g
LS_MEM_LIMIT=1g

# Where Kibana is reachable on the host (just the port).
KIBANA_PORT=5601
ELASTICSEARCH_PORT=9200

# Data retention: events older than this are dropped by ILM.
# Edit the policy in elasticsearch/ilm-policy.json for finer control.
RETENTION_DAYS=90
